---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import type { Lang } from '../i18n';

interface Props {
  title: string;
  lang: Lang;
  description?: string;
}

const { title, lang, description = 'Luis Ramos — Senior Software Engineer portfolio and CV.' } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="bg-[#09090f] text-[#e8e8f0] antialiased overflow-x-hidden">
    <Nav lang={lang} />
    <main>
      <slot />
    </main>
    <footer class="border-t border-[#2a2a3a] py-6 sm:py-8 mt-12 sm:mt-16">
      <div class="max-w-6xl mx-auto px-5 sm:px-6 flex flex-col sm:flex-row justify-between items-center gap-2 sm:gap-3 text-[#6b7280] text-xs sm:text-sm font-mono">
        <span>
          {lang === 'en' ? '© 2024 Luis Ramos. All rights reserved.' : '© 2024 Luis Ramos. Todos los derechos reservados.'}
        </span>
        <span class="text-[10px] sm:text-xs">
          {lang === 'en' ? 'Built with Astro & Tailwind CSS' : 'Hecho con Astro & Tailwind CSS'}
        </span>
      </div>
    </footer>
  </body>
</html>
