---
import '../../styles/cv.css';
import { useTranslations } from '../../i18n';
import type { Lang } from '../../i18n';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'es' } },
  ];
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
const otherLang = lang === 'en' ? 'es' : 'en';

const contactItems = [
  {
    label: t.about.locationValue,
    href: null,
    icon: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
  },
  {
    label: t.contact.email,
    href: `mailto:${t.contact.email}`,
    icon: '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>',
  },
  {
    label: t.contact.linkedin,
    href: `https://${t.contact.linkedin}`,
    external: true,
    icon: '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>',
  },
  {
    label: t.contact.github,
    href: `https://${t.contact.github}`,
    external: true,
    icon: '<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>',
  },
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={t.cv.pageTitle} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&display=swap" rel="stylesheet" />
    <title>{t.cv.pageTitle}</title>
  </head>

  <body class="bg-cv-bg text-cv-ink font-cv text-[17px] leading-relaxed antialiased print:bg-white print:text-[14px]">
    <!-- Accent strip -->
    <div class="h-1 bg-cv-accent print:h-[3px]" aria-hidden="true"></div>

    <div class="max-w-[820px] mx-auto px-8 py-10 max-sm:px-5 max-sm:py-6 print:px-0 print:py-4">
      <!-- Top bar -->
      <div class="flex justify-between items-center mb-8 gap-3 flex-wrap print:hidden">
        <a
          href={`/${lang}/`}
          class="text-[13px] text-cv-muted no-underline transition-colors hover:text-cv-accent"
        >
          &larr; {t.cv.backToPortfolio}
        </a>
        <div class="flex gap-3 items-center">
          <a
            href={`/${otherLang}/cv`}
            class="text-xs px-2.5 py-1 border border-cv-border rounded text-cv-muted no-underline transition-all hover:border-cv-accent hover:text-cv-accent"
          >
            {lang === 'en' ? 'ES' : 'EN'}
          </a>
          <button
            class="flex items-center gap-1.5 py-[7px] px-4 text-[13px] font-medium text-white bg-cv-accent border-none rounded-md cursor-pointer transition-colors hover:bg-cv-accent-hover"
            onclick="window.print()"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
            {t.cv.print}
          </button>
        </div>
      </div>

      <!-- Header -->
      <header class="flex gap-6 items-start mb-8 pb-7 border-b border-cv-border max-sm:gap-4 print:mb-5 print:pb-5 print:gap-4">
        <img
          src="/photo.jpeg"
          alt={t.cv.authorName}
          class="shrink-0 size-[100px] rounded-full object-cover grayscale ring-[3px] ring-cv-accent/25 ring-offset-[3px] ring-offset-cv-bg max-sm:size-[72px] print:size-20 print:ring-offset-white"
        />
        <div class="flex-1 min-w-0">
          <h1 class="text-[32px] font-bold tracking-tight mb-0.5 max-sm:text-[28px] print:text-[28px]">{t.cv.authorName}</h1>
          <p class="text-[19px] text-cv-accent font-medium mb-3 print:text-[17px]">{t.hero.role}</p>
          <div class="flex flex-wrap gap-y-2 gap-x-5 text-[15px] text-cv-muted [&_a]:text-cv-muted [&_a]:no-underline [&_a]:transition-colors hover:[&_a]:text-cv-accent print:[&_a]:text-cv-ink">
            {contactItems.map((item) => (
              <span class="flex items-center gap-1.5">
                <svg class="text-cv-accent/60 print:text-cv-muted" width="14" height="14" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2"
                  stroke-linecap="round" stroke-linejoin="round"
                  set:html={item.icon} />
                {item.href ? (
                  <a
                    href={item.href}
                    {...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                  >{item.label}</a>
                ) : (
                  item.label
                )}
              </span>
            ))}
          </div>
        </div>
      </header>

      <!-- About -->
      <section aria-label={lang === 'en' ? 'Summary' : 'Resumen'} class="mb-8 print:mb-5">
        <p class="text-cv-body text-base leading-[1.75]">{t.cv.about}</p>
      </section>

      <!-- Experience -->
      <section class="mb-8 print:mb-5">
        <h2 class="text-sm font-semibold uppercase tracking-widest text-cv-accent border-l-[3px] border-cv-accent pl-3 mb-5 print:mb-3">{t.cv.sections.experience}</h2>
        {t.experience.roles.map((role, i) => (
          <div class:list={["print:break-inside-avoid", i < t.experience.roles.length - 1 ? "mb-5 print:mb-3.5" : ""]}>
            <div class="flex justify-between items-baseline flex-wrap gap-1 mb-0.5 max-sm:flex-col max-sm:gap-0">
              <span class="text-[17px] font-semibold">{role.title}</span>
              <span class="text-[15px] text-cv-subtle whitespace-nowrap font-light">{role.period}</span>
            </div>
            <p class="text-[15px] text-cv-muted font-medium mb-1">{role.company}</p>
            <p class="text-base text-cv-secondary leading-relaxed mb-2">{role.description}</p>
            <div class="flex flex-wrap gap-1.5">
              {role.stack.map((tech) => (
                <span class="text-[13px] py-0.5 px-2.5 bg-cv-tag-bg text-cv-accent border border-cv-tag-border rounded-full print:bg-transparent print:border-cv-subtle print:text-cv-muted">{tech}</span>
              ))}
            </div>
          </div>
        ))}
      </section>

      <!-- Education -->
      <section class="mb-8 print:mb-5">
        <h2 class="text-sm font-semibold uppercase tracking-widest text-cv-accent border-l-[3px] border-cv-accent pl-3 mb-5 print:mb-3">{t.cv.sections.education}</h2>
        <div class="print:break-inside-avoid">
          <div class="flex justify-between items-baseline flex-wrap gap-1 mb-0.5 max-sm:flex-col max-sm:gap-0">
            <span class="text-[17px] font-semibold">{t.cv.education.degree}</span>
            <span class="text-[15px] text-cv-subtle font-light">{t.cv.education.period}</span>
          </div>
          <p class="text-[15px] text-cv-muted">{t.cv.education.institution}</p>
        </div>
      </section>

      <!-- Skills -->
      <section class="mb-7 print:mb-5">
        <h2 class="text-sm font-semibold uppercase tracking-widest text-cv-accent border-l-[3px] border-cv-accent pl-3 mb-5 print:mb-3">{t.cv.sections.skills}</h2>
        <div class="grid grid-cols-2 gap-4 max-sm:grid-cols-1">
          {t.skills.categories.map((cat) => (
            <div class="print:break-inside-avoid">
              <h3 class="text-[15px] font-semibold mb-1.5">{cat.name}</h3>
              <div class="flex flex-wrap gap-1.5">
                {cat.items.map((item) => (
                  <span class="text-[13px] py-0.5 px-2.5 bg-cv-tag-bg text-cv-accent border border-cv-tag-border rounded-full print:bg-transparent print:border-cv-subtle print:text-cv-muted">{item}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>
    </div>
  </body>
</html>
