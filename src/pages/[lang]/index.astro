---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import About from '../../components/About.astro';
import Experience from '../../components/Experience.astro';
import Skills from '../../components/Skills.astro';
import Contact from '../../components/Contact.astro';
import { useTranslations } from '../../i18n';
import type { Lang } from '../../i18n';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'es' } },
  ];
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);

const titles: Record<Lang, string> = {
  en: 'Luis Ramos — Senior Software Engineer',
  es: 'Luis Ramos — Senior Software Engineer',
};

const descriptions: Record<Lang, string> = {
  en: 'Portfolio and CV of Luis Ramos, Senior Software Engineer with 7+ years of experience.',
  es: 'Portafolio y CV de Luis Ramos, Senior Software Engineer con más de 7 años de experiencia.',
};
---

<Layout title={titles[lang]} lang={lang} description={descriptions[lang]}>
  <Hero t={t} />
  <About t={t} />
  <Experience t={t} />
  <Skills t={t} />
  <Contact t={t} />
</Layout>
