---
import type { Translations } from '../i18n/en';
import SkillBars from './SkillBars.astro';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const s = t.skills;

const categoryColors = [
  { accent: '#00d4ff', bg: '#00d4ff12', border: '#00d4ff26' },
  { accent: '#7b61ff', bg: '#7b61ff12', border: '#7b61ff26' },
  { accent: '#ff6b6b', bg: '#ff6b6b12', border: '#ff6b6b26' },
];
---

<section id="skills" class="py-16 sm:py-20 md:py-24 border-t border-[#2a2a3a]">
  <div class="max-w-6xl mx-auto px-5 sm:px-6">
    <!-- Section label -->
    <div class="flex items-center gap-4 mb-10 sm:mb-12">
      <span class="font-mono text-xs text-[#00d4ff] tracking-widest uppercase">{s.label}</span>
      <div class="h-px flex-1 bg-gradient-to-r from-[#2a2a3a] to-transparent"></div>
    </div>

    <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight mb-8 sm:mb-10">{s.title}</h2>

    <!-- Bento-style grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4">
      {s.categories.map((cat, i) => {
        const color = categoryColors[i] ?? categoryColors[0];
        return (
          <div
            class="rounded-lg sm:rounded-xl p-4 sm:p-5 md:p-6 border transition-all duration-300 hover:-translate-y-1 group"
            style={`background: #111118; border-color: #2a2a3a;`}
          >
            <!-- Category header -->
            <div class="flex items-center gap-3 mb-4">
              <div
                class="w-7 h-7 sm:w-8 sm:h-8 rounded-lg flex items-center justify-center shrink-0"
                style={`background: ${color.bg}; border: 1px solid ${color.border};`}
              >
                <span class="font-mono text-[10px] sm:text-xs font-bold" style={`color: ${color.accent};`}>
                  {cat.name.slice(0, 2).toUpperCase()}
                </span>
              </div>
              <h3 class="font-semibold text-sm text-[#e8e8f0]">{cat.name}</h3>
            </div>

            <!-- Skills -->
            <div class="flex flex-wrap gap-1.5 sm:gap-2">
              {cat.items.map((skill) => (
                <span
                  class="font-mono text-[11px] sm:text-xs px-2.5 sm:px-3 py-1 sm:py-1.5 rounded-lg border transition-colors duration-150 cursor-default hover:opacity-90"
                  style={`background: ${color.bg}; color: ${color.accent}; border-color: ${color.border};`}
                >
                  {skill}
                </span>
              ))}
            </div>
          </div>
        );
      })}
    </div>

    <!-- Skill proficiency bars -->
    <!-- <SkillBars skills={[
      { label: 'TypeScript', pct: 95 },
      { label: 'React', pct: 90 },
      { label: 'Node.js', pct: 88 },
      { label: 'PostgreSQL', pct: 80 },
      { label: 'AWS', pct: 72 },
    ]} /> -->
  </div>
</section>
